# Application Configuration
APP_NAME=KoiboiStudy
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/koiboi_study

# JWT Configuration
JWT_SECRET=your-secret-key-min-32-characters-long-for-security
JWT_EXPIRATION_HOURS=24

# Cloud Storage Configuration
STORAGE_TYPE=s3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=koiboi-materials
AWS_REGION=us-east-1

# Email Service Configuration
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@koiboi.app

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://koiboi.app

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379/0
